# PaRacORD TLS reverse proxy (AUDIT D3) — copy to config/Caddyfile and adjust.
#
# LAN without a public domain: Caddy's `internal` issuer mints certificates from its own local CA.
# Trust that CA on each client machine (browser + agent):
#   * export it:   docker compose exec caddy cat /data/caddy/pki/authorities/local/root.crt
#   * browser:     import root.crt as a trusted CA (or accept the warning once)
#   * agent:       set `ca_cert: /path/to/root.crt` in the agent config
# With a real domain, replace the site address and delete the `tls internal` line —
# Caddy fetches Let's Encrypt certificates automatically.

# Replace with your server's LAN name/IP (e.g. paracord.lan, 192.168.1.10).
https://paracord.lan {
	tls internal

	# API + websockets
	handle /api/* {
		reverse_proxy api:8000
	}
	# Frontend (nginx static bundle in prod)
	handle {
		reverse_proxy frontend:80
	}
}
