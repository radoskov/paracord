PARACORD_ENV=development
PARACORD_SERVER_CONFIG=config/server.local.yaml
PARACORD_AGENT_CONFIG=config/agent.local.yaml
POSTGRES_USER=paperracks
POSTGRES_PASSWORD=paperracks_dev_password
POSTGRES_DB=paperracks
DATABASE_URL=postgresql+psycopg://paperracks:paperracks_dev_password@localhost:5432/paperracks
REDIS_URL=redis://localhost:6379/0
GROBID_URL=http://localhost:8070
OLLAMA_URL=http://localhost:11434

# Production only: URL the browser uses to reach the API (baked into the frontend bundle at
# npm run build time).  Set to your server address before running `make prod-build`.
# Example: VITE_API_BASE_URL=http://192.168.1.10:8000
VITE_API_BASE_URL=http://127.0.0.1:8000

# Production only: number of gunicorn worker processes (default 2).
# GUNICORN_WORKERS=4
